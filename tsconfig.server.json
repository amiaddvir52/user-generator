{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "rootDir": "src",
    "outDir": "dist",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/server/**/*.ts",
    "src/shared/**/*.ts",
    "src/cli/**/*.ts",
    "src/tug/**/*.ts"
  ],
  "exclude": [
    "src/server/**/*.test.ts"
  ]
}
